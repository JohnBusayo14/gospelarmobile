# Frontend (Expo) public env vars — copy to frontend/.env and tweak as needed.
# IMPORTANT: only EXPO_PUBLIC_* prefixed vars are exposed to the React Native
# bundle. Anything else is dropped at build time. NEVER put secrets here —
# values land in the shipped bundle and are visible to anyone who inspects it.

# Backend base URL the app calls. Default = api.gospelar.com (CNAME → Railway).
# For local dev use your machine's LAN IP (so a phone on the same WiFi can
# reach it), e.g. http://192.168.1.42:5000. NO trailing slash.
EXPO_PUBLIC_API_BASE_URL=https://api.gospelar.com

# (Paystack credentials live ONLY on the backend now — PAYSTACK_SECRET_KEY
# in backend/.env. The mobile app calls /api/payments/initialize and opens
# the returned authorization_url in a WebView. No public key needed in the
# bundle.)
